# Your Atlassian site URL
ROVO_BASE_URL="https://yoursite.atlassian.net"

# Session token from browser cookies (see README for how to grab this)
ROVO_SESSION_TOKEN="eyJraWQ..."

# XSRF token from browser cookies
ROVO_XSRF_TOKEN="abc123..."

# Conversation ID - start a Rovo chat in your browser, grab from network tab
ROVO_CONVERSATION_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Optional: URL context for Rovo (defaults to ROVO_BASE_URL)
# ROVO_CONTEXT_URL="https://yoursite.atlassian.net/wiki/spaces/MYSPACE/pages/123456"

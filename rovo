#!/bin/bash
#
# hey-rovo - Talk to Atlassian Rovo from your terminal
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${ROVO_ENV_FILE:-$SCRIPT_DIR/.env}"

if [ ! -f "$ENV_FILE" ]; then
  echo "Missing .env file at $ENV_FILE"
  echo "Copy .env.example to .env and fill in your values."
  echo "See README.md for how to grab your session token."
  exit 1
fi

set -a
source "$ENV_FILE"
set +a

if [ -z "${ROVO_SESSION_TOKEN:-}" ]; then
  echo "Missing ROVO_SESSION_TOKEN in $ENV_FILE"
  exit 1
fi
if [ -z "${ROVO_BASE_URL:-}" ]; then
  echo "Missing ROVO_BASE_URL in $ENV_FILE"
  exit 1
fi

# Each invocation gets a fresh conversation (or reuse one from .env)
CONV_ID="${ROVO_CONVERSATION_ID:-$(uuidgen | tr '[:upper:]' '[:lower:]')}"

QUERY="${*:-hello}"

curl -s "${ROVO_BASE_URL}/gateway/api/assist/rovo/v1/chat/conversation/${CONV_ID}/message/stream/sse" \
  -H "Cookie: tenant.session.token=${ROVO_SESSION_TOKEN}" \
  -H 'x-atlassian-token: no-check' \
  -H 'content-type: application/json;charset=UTF-8' \
  -H 'x-product: confluence' \
  -H 'x-channel-id: rovo-chat' \
  -H 'x-experience-id: ai-mate' \
  --data-raw "{\"content\":{\"version\":1,\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"$(echo "$QUERY" | sed 's/\\/\\\\/g; s/"/\\"/g')\"}]}]},\"context\":{\"browser_url\":\"${ROVO_CONTEXT_URL:-${ROVO_BASE_URL}}\",\"useCurrentBrowsingContext\":false,\"webSearchEnabled\":false,\"deepResearchEnabled\":false,\"creationContext\":{\"isStagingArea\":false,\"productKey\":\"confluence\",\"isViewMode\":false},\"userTimezone\":\"$(cat /etc/timezone 2>/dev/null || echo 'UTC')\",\"fileIds\":[]},\"mimeType\":\"text/adf\",\"store_message\":false,\"citations_enabled\":true}" \
| grep '^data:' | grep 'ANSWER_PART' \
| sed 's/^data://; s/.*"content":"//; s/","role.*//' \
| while IFS= read -r chunk; do printf '%b' "$chunk"; done
echo
